---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const slugify = (str: string) =>
	str
		.toLowerCase()
		.replace(/[^a-z0-9\s]/g, '')
		.trim()
		.replace(/\s+/g, '-');

// Build unique category list with post counts
const categoriesMap = new Map<string, number>();
for (const post of allPosts) {
	if (post.data.category) {
		categoriesMap.set(
			post.data.category,
			(categoriesMap.get(post.data.category) ?? 0) + 1,
		);
	}
}
const categories = [...categoriesMap.entries()].sort((a, b) => b[1] - a[1]);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1100px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em 4em;
			}

			.blog-header {
				margin-bottom: 2.5rem;
				border-bottom: 2px solid #e8e8e8;
				padding-bottom: 1.5rem;
			}
			.blog-header h1 {
				margin: 0 0 0.4rem;
				font-size: 2.2rem;
			}
			.blog-header p {
				color: rgb(var(--gray));
				margin: 0;
			}

			.blog-layout {
				display: grid;
				grid-template-columns: 1fr 260px;
				gap: 3rem;
				align-items: start;
			}

			/* ── Posts list ── */
			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 1.8rem;
			}

			.post-card {
				display: grid;
				grid-template-columns: 200px 1fr;
				gap: 1.2rem;
				background: white;
				border: 1px solid #e8e8e8;
				border-radius: 12px;
				overflow: hidden;
				transition: box-shadow 0.2s, transform 0.2s;
				text-decoration: none;
				color: inherit;
			}
			.post-card:hover {
				box-shadow: var(--box-shadow);
				transform: translateY(-2px);
			}
			.post-card.no-img {
				grid-template-columns: 1fr;
			}

			.post-card img {
				width: 100%;
				height: 140px;
				object-fit: cover;
			}

			.post-card-body {
				padding: 1rem 1rem 1rem 0;
				display: flex;
				flex-direction: column;
				gap: 0.45rem;
				justify-content: center;
			}
			.post-card.no-img .post-card-body {
				padding: 1.2rem 1.4rem;
			}

			.post-card-body h2 {
				margin: 0;
				font-size: 1.15rem;
				line-height: 1.35;
				color: rgb(var(--black));
			}
			.post-card:hover h2 {
				color: rgb(var(--accent));
			}

			.post-card-body .desc {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				flex-wrap: wrap;
				margin-top: 0.2rem;
			}

			.post-date {
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}

			.category-badge {
				font-size: 0.75rem;
				padding: 0.15rem 0.6rem;
				border-radius: 999px;
				background: rgb(var(--accent-light));
				color: rgb(var(--accent));
				font-weight: 600;
				text-decoration: none;
				transition: background 0.2s;
			}
			.category-badge:hover {
				background: rgb(var(--accent));
				color: white;
			}

			.tag {
				font-size: 0.73rem;
				color: rgb(var(--gray));
			}

			/* ── Sidebar ── */
			.sidebar {
				position: sticky;
				top: 5rem;
			}

			.sidebar-card {
				background: white;
				border: 1px solid #e8e8e8;
				border-radius: 12px;
				padding: 1.4rem;
				margin-bottom: 1.5rem;
			}

			.sidebar-card h3 {
				margin: 0 0 1rem;
				font-size: 1rem;
				color: rgb(var(--black));
				display: flex;
				align-items: center;
				gap: 0.4rem;
			}

			.category-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}

			.category-list a {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.45rem 0.7rem;
				border-radius: 8px;
				text-decoration: none;
				color: rgb(var(--black));
				font-size: 0.9rem;
				transition: background 0.15s, color 0.15s;
			}
			.category-list a:hover {
				background: rgb(var(--accent-light));
				color: rgb(var(--accent));
			}

			.category-count {
				font-size: 0.8rem;
				background: #f0f0f0;
				color: rgb(var(--gray));
				padding: 0.1rem 0.5rem;
				border-radius: 999px;
			}

			.tags-cloud {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
			}
			.tags-cloud span {
				font-size: 0.8rem;
				padding: 0.2rem 0.6rem;
				border-radius: 999px;
				background: #f5f5f5;
				color: rgb(var(--gray));
			}

			/* ── Responsive ── */
			@media (max-width: 800px) {
				.blog-layout {
					grid-template-columns: 1fr;
				}
				.sidebar {
					position: static;
				}
				.post-card {
					grid-template-columns: 1fr;
				}
				.post-card img {
					height: 180px;
				}
				.post-card-body {
					padding: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-header">
				<h1>📝 Blog</h1>
				<p>Notes on AI, ML, and engineering. {allPosts.length} post{allPosts.length !== 1 ? 's' : ''} so far.</p>
			</div>

			<div class="blog-layout">
				<!-- Posts -->
				<div class="posts-list">
					{
						allPosts.map((post) => (
							<a
								href={`/blog/${post.id}/`}
								class={`post-card ${!post.data.heroImage ? 'no-img' : ''}`}
							>
								{post.data.heroImage && (
									<Image
										width={200}
										height={140}
										src={post.data.heroImage}
										alt=""
									/>
								)}
								<div class="post-card-body">
									<h2>{post.data.title}</h2>
									<p class="desc">{post.data.description}</p>
									<div class="post-meta">
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										{post.data.category && (
											<a
												href={`/blog/category/${slugify(post.data.category)}/`}
												class="category-badge"
												onclick="event.stopPropagation()"
											>
												{post.data.category}
											</a>
										)}
										{post.data.tags?.slice(0, 2).map((tag) => (
											<span class="tag">#{tag}</span>
										))}
									</div>
								</div>
							</a>
						))
					}
				</div>

				<!-- Sidebar -->
				<aside class="sidebar">
					{
						categories.length > 0 && (
							<div class="sidebar-card">
								<h3>📂 Categories</h3>
								<ul class="category-list">
									{categories.map(([name, count]) => (
										<li>
											<a href={`/blog/category/${slugify(name)}/`}>
												<span>{name}</span>
												<span class="category-count">{count}</span>
											</a>
										</li>
									))}
								</ul>
							</div>
						)
					}

					<div class="sidebar-card">
						<h3>🏷️ Tags</h3>
						<div class="tags-cloud">
							{
								[
									...new Set(
										allPosts.flatMap((p) => p.data.tags ?? []),
									),
								].map((tag) => <span>#{tag}</span>)
							}
						</div>
					</div>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>

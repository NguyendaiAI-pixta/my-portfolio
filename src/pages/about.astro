---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_AUTHOR } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.about-container {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem;
			}
			.hero-section {
				text-align: center;
				margin-bottom: 3rem;
			}
			.profile-img {
				width: 200px;
				height: 200px;
				border-radius: 50%;
				object-fit: cover;
				margin-bottom: 1.5rem;
				border: 4px solid var(--accent);
			}
			.about-section {
				margin-bottom: 3rem;
			}
			.about-section h2 {
				color: var(--accent);
				margin-bottom: 1rem;
			}
			.skills-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5rem;
				margin-top: 1.5rem;
			}
			.skill-category h3 {
				color: var(--accent);
				margin-bottom: 0.5rem;
				font-size: 1.1rem;
			}
			.skill-category ul {
				list-style: none;
				padding: 0;
			}
			.skill-category li {
				padding: 0.3rem 0;
				color: var(--gray-dark);
			}
			.skill-category li:before {
				content: "▹ ";
				color: var(--accent);
				font-weight: bold;
			}
			.interests {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				margin-top: 1rem;
			}
			.interest-tag {
				background: var(--bg-secondary, #f5f5f5);
				padding: 0.5rem 1rem;
				border-radius: 20px;
				font-size: 0.9rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="about-container">
			<div class="hero-section">
				<!-- Uncomment and add your photo -->
				<!-- <img src="/profile.jpg" alt={SITE_AUTHOR} class="profile-img" /> -->
				<div style="width: 200px; height: 200px; border-radius: 50%; background: var(--accent); margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; font-size: 4rem;">
					👤
				</div>
				<h1>About Me</h1>
				<p style="font-size: 1.2rem; color: var(--gray);">
					Developer | Writer | Learner
				</p>
			</div>

			<div class="about-section">
				<h2>Who I Am</h2>
				<p>
					Hi! I'm {SITE_AUTHOR}, a passionate developer and technology enthusiast. 
					I love building things and sharing what I learn along the way.
				</p>
				<p>
					This blog is where I document my journey in technology, share insights,
					and connect with other developers and curious minds. I believe in learning 
					in public and giving back to the community that has helped me grow.
				</p>
			</div>

			<div class="about-section">
				<h2>What I Do</h2>
				<p>
					I work on various projects ranging from web development to machine learning,
					always eager to explore new technologies and solve challenging problems.
				</p>
				<div class="skills-grid">
					<div class="skill-category">
						<h3>Languages</h3>
						<ul>
							<li>Python</li>
							<li>JavaScript/TypeScript</li>
							<li>Java</li>
							<li>SQL</li>
						</ul>
					</div>
					<div class="skill-category">
						<h3>Frontend</h3>
						<ul>
							<li>React</li>
							<li>Astro</li>
							<li>HTML/CSS</li>
							<li>Tailwind CSS</li>
						</ul>
					</div>
					<div class="skill-category">
						<h3>Backend</h3>
						<ul>
							<li>Node.js</li>
							<li>FastAPI</li>
							<li>Express</li>
							<li>PostgreSQL</li>
						</ul>
					</div>
					<div class="skill-category">
						<h3>Tools & Others</h3>
						<ul>
							<li>Git & GitHub</li>
							<li>Docker</li>
							<li>AWS/Cloud</li>
							<li>CI/CD</li>
						</ul>
					</div>
				</div>
			</div>

			<div class="about-section">
				<h2>Interests</h2>
				<div class="interests">
					<span class="interest-tag">🚀 Web Development</span>
					<span class="interest-tag">🤖 Machine Learning</span>
					<span class="interest-tag">☁️ Cloud Computing</span>
					<span class="interest-tag">📚 Technical Writing</span>
					<span class="interest-tag">🎨 UI/UX Design</span>
					<span class="interest-tag">🔧 DevOps</span>
					<span class="interest-tag">🌐 Open Source</span>
				</div>
			</div>

			<div class="about-section">
				<h2>Let's Connect</h2>
				<p>
					I'm always interested in hearing about new projects and opportunities.
					Feel free to reach out if you want to collaborate or just say hi!
				</p>
				<p>
					<a href="/contact" style="color: var(--accent); font-weight: bold;">
						Get in touch →
					</a>
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
